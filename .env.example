# ============================================================================
# Enterprise Chatbot Framework - Environment Configuration Example
# ============================================================================
# Copy this file to .env and fill in your actual values
# 
# This file contains example values for all configuration options.
# Some are required, others are optional. See comments for details.
# ============================================================================

# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================

# Anthropic Claude API Key (REQUIRED)
# Get your key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API Key (REQUIRED)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# WEAVIATE VECTOR DATABASE CONFIGURATION
# ============================================================================

# Weaviate Server Host (REQUIRED)
# For local development: localhost
# For production: your-weaviate-host.example.com
WEAVIATE_HOST=localhost

# Weaviate Server Port (Optional, default: 8080)
WEAVIATE_PORT=8080

# Weaviate API Key (Optional, for hosted Weaviate)
# Leave blank for local development without authentication
WEAVIATE_API_KEY=

# Use Embedded Weaviate (Optional, default: false)
# Set to "true" to use embedded Weaviate instead of connecting to server
USE_EMBEDDED_WEAVIATE=false

# ============================================================================
# CONFLUENCE CONFIGURATION
# ============================================================================

# Confluence Base URL (REQUIRED)
# Example: https://yourcompany.atlassian.net
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net

# Confluence Authentication Type (REQUIRED)
# Options: "api_token" or "oauth"
CONFLUENCE_AUTH_TYPE=api_token

# === API Token Authentication ===
# Only needed if CONFLUENCE_AUTH_TYPE=api_token

# Confluence Username/Email (for API token auth)
CONFLUENCE_USERNAME=your-email@example.com

# Confluence API Token (for API token auth)
# Generate from: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === OAuth Authentication ===
# Only needed if CONFLUENCE_AUTH_TYPE=oauth

# Confluence OAuth Client ID
CONFLUENCE_OAUTH_CLIENT_ID=

# Confluence OAuth Client Secret
CONFLUENCE_OAUTH_CLIENT_SECRET=

# Confluence OAuth Token URL
CONFLUENCE_OAUTH_TOKEN_URL=https://yourcompany.atlassian.net/oauth/authorize

# ============================================================================
# DOCUMENT AND CODE REPOSITORY CONFIGURATION
# ============================================================================

# Document Paths (Optional)
# Comma-separated paths to local documents or document sources
# Examples: "/path/to/docs,/path/to/knowledge-base"
DOCUMENT_PATHS=

# Code Repository Paths (Optional)
# Comma-separated paths to code repositories for indexing
# Examples: "/path/to/repo1,/path/to/repo2"
CODE_REPO_PATHS=

# ============================================================================
# EMBEDDING MODEL CONFIGURATION
# ============================================================================

# Embedding Model Name (Optional, default: sentence-transformers/all-MiniLM-L6-v2)
# HuggingFace model ID for embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================================
# CONTEXT AND CONVERSATION SETTINGS
# ============================================================================

# Maximum Context Tokens (Optional, default: 2000)
# Maximum number of tokens to include in the context window
MAX_CONTEXT_TOKENS=2000

# Maximum Conversation History (Optional, default: 10)
# Maximum number of previous messages to keep in conversation history
MAX_CONVERSATION_HISTORY=10

# ============================================================================
# FASTAPI SERVER CONFIGURATION
# ============================================================================

# FastAPI Server Host (Optional, default: 0.0.0.0)
# 0.0.0.0 = listen on all network interfaces
# 127.0.0.1 = localhost only
FASTAPI_HOST=0.0.0.0

# FastAPI Server Port (Optional, default: 8000)
FASTAPI_PORT=8000

# ============================================================================
# Optional: Development Settings
# ============================================================================

# Enable Debug Mode (Optional, default: false)
# DEBUG=false

# Log Level (Optional, default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
